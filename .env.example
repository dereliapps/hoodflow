# Never commit a funded production key. Use a dedicated, low-balance testnet wallet.
ROBINHOOD_TESTNET_RPC_URL=https://rpc.testnet.chain.robinhood.com
ROBINHOOD_TESTNET_PRIVATE_KEY=0xYOUR_TESTNET_ONLY_PRIVATE_KEY
ROBINHOOD_MAINNET_RPC_URL=https://rpc.mainnet.chain.robinhood.com
ROBINHOOD_FORK_BLOCK_NUMBER=10453077

# Keeper process
HOODFLOW_CONTRACT_ADDRESS=0xDEPLOYED_CONTRACT
HOODFLOW_CHAIN_ID=46630
HOODFLOW_RPC_URL=https://rpc.testnet.chain.robinhood.com
HOODFLOW_KEEPER_PRIVATE_KEY=0xDEDICATED_LOW_BALANCE_KEEPER_KEY
HOODFLOW_V4_QUOTER=0xUNISWAP_V4_QUOTER
KEEPER_POLL_INTERVAL_MS=15000
KEEPER_CONFIRMATIONS=1
KEEPER_MAX_STRATEGIES=500

# Deployment safety: all addresses must be provided explicitly.
HOODFLOW_INITIAL_OWNER=0xFINAL_MULTISIG_OR_TESTNET_OWNER
HOODFLOW_GUARDIAN=0xSEPARATE_GUARDIAN
HOODFLOW_UNIVERSAL_ROUTER=0xREVIEWED_UNIVERSAL_ROUTER
HOODFLOW_PERMIT2=0xREVIEWED_PERMIT2
HOODFLOW_FEE_RECIPIENT=0xFEE_RECIPIENT
HOODFLOW_INITIAL_FEE_BPS=10
HOODFLOW_KEEPERS=0xKEEPER_ONE,0xKEEPER_TWO
HOODFLOW_SEQUENCER_UPTIME_FEED=0xCHAINLINK_SEQUENCER_UPTIME_FEED
HOODFLOW_SEQUENCER_GRACE_PERIOD_SECONDS=3600
# JSON: [{"token":"0x...","feed":"0x...","heartbeat":3600,"checkOraclePause":true}]
HOODFLOW_TOKEN_CONFIGS=[]
# Must be typed exactly as true; otherwise deployment remains safely paused.
HOODFLOW_UNPAUSE_AFTER_DEPLOY=false
