# Never commit a funded production key. Use a dedicated, low-balance testnet wallet.
ROBINHOOD_TESTNET_RPC_URL=https://rpc.testnet.chain.robinhood.com
ROBINHOOD_TESTNET_PRIVATE_KEY=0xYOUR_TESTNET_ONLY_PRIVATE_KEY
ROBINHOOD_MAINNET_RPC_URL=https://rpc.mainnet.chain.robinhood.com
ROBINHOOD_FORK_BLOCK_NUMBER=10453077
# Keep this only in a local secret store during the paused deployment. Never commit it.
HOODFLOW_DEPLOYER_PRIVATE_KEY=

# Public frontend configuration. Leave blank until the recurring engine bytecode is verified.
# Direct USDG buys use the canonical Universal Router and do not depend on this address.
NEXT_PUBLIC_HOODFLOW_CONTRACT_ADDRESS=0x234beb689a3e5d7E930D6aBBEaD6B39e47FEdc98

# Privy public identifiers. Enable Email, Google, Twitter, Passkey and Wallet in the Privy dashboard.
# Never place a Privy app secret in a NEXT_PUBLIC variable.
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_PRIVY_CLIENT_ID=

# Production release reads must agree through two independent providers.
# The public Robinhood endpoint above is rate-limited and is only used by local verification.
ROBINHOOD_MAINNET_RPC_URL_PRIMARY=https://YOUR_PRIMARY_PRODUCTION_PROVIDER
ROBINHOOD_MAINNET_RPC_URL_SECONDARY=https://YOUR_SECONDARY_PRODUCTION_PROVIDER

# Keeper process
HOODFLOW_CONTRACT_ADDRESS=0xDEPLOYED_CONTRACT
HOODFLOW_CHAIN_ID=4663
HOODFLOW_RPC_URL=https://YOUR_PRIMARY_PRODUCTION_PROVIDER
HOODFLOW_KEEPER_PRIVATE_KEY=0xDEDICATED_LOW_BALANCE_KEEPER_KEY
HOODFLOW_V4_QUOTER=0x8dc178efb8111bb0973dd9d722ebeff267c98f94
KEEPER_POLL_INTERVAL_MS=15000
KEEPER_CONFIRMATIONS=1
KEEPER_MAX_STRATEGIES=500
KEEPER_READINESS_MAX_AGE_MS=60000
KEEPER_READINESS_FAILURE_THRESHOLD=3
KEEPER_HEALTH_HOST=127.0.0.1
KEEPER_HEALTH_PORT=8787

# Deployment safety: all addresses must be provided explicitly.
HOODFLOW_INITIAL_OWNER=0xFINAL_MULTISIG_OR_TESTNET_OWNER
HOODFLOW_GUARDIAN=0xSEPARATE_GUARDIAN
HOODFLOW_UNIVERSAL_ROUTER=0xREVIEWED_UNIVERSAL_ROUTER
HOODFLOW_PERMIT2=0xREVIEWED_PERMIT2
HOODFLOW_FEE_RECIPIENT=0xFEE_RECIPIENT
HOODFLOW_INITIAL_FEE_BPS=10
HOODFLOW_SETTLEMENT_TOKEN=0x5fc5360D0400a0Fd4f2af552ADD042D716F1d168
# USDG has 6 decimals: 25 USDG per execution, 500 USDG lifetime cap.
HOODFLOW_MAX_TRANCHE_AMOUNT=25000000
HOODFLOW_MAX_STRATEGY_BUDGET=500000000
HOODFLOW_KEEPERS=0xKEEPER_ONE,0xKEEPER_TWO
HOODFLOW_MAINNET_DEPLOY_ACK=
HOODFLOW_DEPLOY_CONFIRMATIONS=2
HOODFLOW_SEQUENCER_MODE=none
HOODFLOW_SEQUENCER_UPTIME_FEED=0xCHAINLINK_SEQUENCER_UPTIME_FEED
HOODFLOW_SEQUENCER_GRACE_PERIOD_SECONDS=0
# JSON: [{"token":"0x...","feed":"0x...","heartbeat":3600,"checkOraclePause":true}]
HOODFLOW_TOKEN_CONFIGS=[]
# Must be typed exactly as true; otherwise deployment remains safely paused.
HOODFLOW_UNPAUSE_AFTER_DEPLOY=false

# Mainnet release gate. These values are evidence, not secrets.
HOODFLOW_RELEASE_APPROVERS=0xRELEASE_REVIEWER_ONE,0xRELEASE_REVIEWER_TWO
HOODFLOW_AUDIT_PROVIDER=INDEPENDENT_AUDITOR_NAME
HOODFLOW_AUDIT_REPORT_PATH=C:\SECURE\PATH\hoodflow-final-audit.pdf
HOODFLOW_AUDIT_REPORT_SHA256=64_HEX_CHARACTERS
HOODFLOW_AUDIT_STATUS=pending
HOODFLOW_CANARY_RPC_URL=https://YOUR_ROBINHOOD_TESTNET_PROVIDER
HOODFLOW_CANARY_CHAIN_ID=46630
HOODFLOW_CANARY_TX_HASH=0x64_HEX_CHARACTERS
HOODFLOW_CANARY_STATUS=pending
HOODFLOW_MONITORING_READY=false
HOODFLOW_INCIDENT_DRILL_STATUS=pending
HOODFLOW_SOURCE_COMMIT=40_HEX_GIT_COMMIT

# Post-deployment read-only verification. Keep the engine paused for this check.
HOODFLOW_ADAPTER_ADDRESS=0xDEPLOYED_ADAPTER
