{
  "name": "hoodflow",
  "version": "0.7.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0",
    "npm": ">=10.9.0"
  },
  "scripts": {
    "dev": "cross-env WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "cross-env WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "cross-env WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "npm run test:contracts && npm run test:release && npm run test:site",
    "test:site": "npm run build && node --test tests/rendered-html.test.mjs",
    "test:contracts": "hardhat test",
    "test:release": "node --import tsx --test tests/mainnet-release.test.ts tests/prices.test.ts tests/router-calldata.test.ts tests/virtuals-market.test.ts",
    "contracts:compile": "hardhat compile --build-profile production",
    "contracts:clean": "hardhat clean",
    "contracts:deploy:testnet": "hardhat run scripts/deploy-testnet.ts",
    "contracts:deploy:mainnet:paused": "hardhat run scripts/deploy-mainnet-paused.ts --network robinhoodMainnet",
    "infra:verify:mainnet": "tsx scripts/verify-robinhood-mainnet.ts",
    "infra:verify:fork": "hardhat run scripts/verify-v4-fork.ts",
    "infra:verify:direct-buy": "hardhat run scripts/verify-direct-buy-fork.ts",
    "infra:verify:canary": "hardhat run scripts/verify-canary-fork.ts",
    "infra:verify:bootstrap": "hardhat run scripts/verify-bootstrap-fork.ts",
    "launch:preflight": "npm run contracts:compile && npm test && npm run infra:verify:mainnet && npm run infra:verify:fork && npm run infra:verify:direct-buy && npm run infra:verify:canary",
    "mainnet:preflight": "tsx scripts/verify-release-config.ts",
    "mainnet:preflight:offline": "tsx scripts/verify-release-config.ts --offline",
    "mainnet:verify:deployment": "tsx scripts/verify-deployment.ts",
    "keeper:dry-run": "tsx keeper/index.ts --dry-run",
    "keeper:start": "tsx keeper/index.ts",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next --ignore-pattern artifacts --ignore-pattern cache --ignore-pattern typechain-types --ignore-pattern work --ignore-pattern .vinext --ignore-pattern .wrangler",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1",
    "@walletconnect/ethereum-provider": "^2.23.10",
    "drizzle-orm": "0.45.2",
    "ethers": "^6.17.0",
    "next": "16.2.10",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.45.0",
    "@cloudflare/workers-types": "^5.20260715.1",
    "@nomicfoundation/hardhat-ethers": "^4.0.14",
    "@nomicfoundation/hardhat-ethers-chai-matchers": "^3.0.11",
    "@nomicfoundation/hardhat-mocha": "^3.0.21",
    "@nomicfoundation/hardhat-network-helpers": "^3.0.11",
    "@tailwindcss/postcss": "4.2.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "chai": "^6.2.2",
    "cross-env": "^10.1.0",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "hardhat": "^3.9.1",
    "mocha": "^11.7.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "tsx": "^4.23.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "^8.1.4",
    "wrangler": "^4.111.0"
  },
  "type": "module",
  "overrides": {
    "next": {
      "postcss": "8.5.19"
    },
    "mocha": {
      "diff": "8.0.3",
      "serialize-javascript": "7.0.5"
    }
  }
}
